{
  "name": "telezero",
  "version": "1.0.0",
  "description": "TeleZero is a lightweight TypeScript autonomous agent that runs via Telegram and a local dashboard",
  "main": "index.js",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "telezero": "tsx scripts/dev.ts",
    "build": "tsc && mkdir -p dist/workspace && cp -r src/workspace/skills dist/workspace/ && cp src/workspace/SOUL.md dist/workspace/ && cp src/workspace/IDENTITY.md dist/workspace/ && cp src/workspace/USER.md dist/workspace/ && cp src/workspace/TOOLS.md dist/workspace/ && cp src/workspace/HEARTBEAT.md dist/workspace/ && cp src/workspace/AGENT_STEP.md dist/workspace/ && cp src/database/schema.sql dist/database/schema.sql",
    "start": "node dist/index.js",
    "test": "jest",
    "db:migrate": "tsx scripts/migrate.ts",
    "agent": "tsx scripts/run-agent-task.ts",
    "dashboard": "tsx scripts/dashboard.ts",
    "dashboard:build": "vite build",
    "dashboard:dev": "vite"
  },
  "keywords": [],
  "author": "ronaldaug <https://github.com/ronaldaug>",
  "license": "GPL-3.0",
  "type": "module",
  "dependencies": {
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gramio": "^0.7.0",
    "node-cron": "^4.2.1",
    "openai": "^6.27.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  }
}
